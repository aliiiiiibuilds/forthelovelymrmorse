// Vault Platform - PostgreSQL Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  locked       Boolean  @default(true)
  status       String   @default("FREE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversation  Conversation?
  uploads       UploadedFile[]
  notifications Notification[]
}

model Agent {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Conversation {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  messages     Message[]
  agentUnread  Int       @default(0)
  playerUnread Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         String       // PLAYER | AGENT
  content        String?
  imageUrl       String?
  isIdImage      Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Game {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  link        String
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentMethod {
  id        String   @id @default(cuid())
  type      String
  name      String
  tag       String
  qrCodeUrl String?
  note      String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promo {
  id          String    @id @default(cuid())
  title       String
  code        String    @unique
  description String
  expiresAt   DateTime?
  statuses    String    @default("FREE,VIP,VVIP")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SiteSettings {
  id           String   @id @default("singleton")
  messageOfDay String   @default("Welcome to Vault Platform!")
  depositTag   String   @default("")
  redeemTag    String   @default("")
  updatedAt    DateTime @updatedAt
}

model UploadedFile {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  filename  String
  url       String
  mimetype  String
  createdAt DateTime @default(now())
}
